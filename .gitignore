# =============================================================================
#  Root .gitignore — safety net for the whole monorepo
#  (backend/, frontend/, admin/ each also have their own .gitignore)
# =============================================================================

# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
**/dist/
build/

# Environment / secrets
.env
.env.*
!.env.example
**/.env
!**/.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test / coverage
coverage/

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
